# ── PPG / PaPaGei model ────────────────────────────────────────────────────────
# Path to pre-trained PaPaGei-S weights (.pt file).
# Download from: https://zenodo.org/record/13983110
MODEL_PATH=weights/papagei_s.pt

# Device for PyTorch inference: 'cpu' or 'cuda'
DEVICE=cpu

# ── Clinical explanation models (MedGemma) ─────────────────────────────────────
# Google AI Studio API key — used for MedGemma-4b-it via the Gemini API.
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Override the MedGemma model variant (optional; default: medgemma-4b-it)
# MEDGEMMA_MODEL_ID=medgemma-4b-it

# Set to any non-empty value to load MedGemma locally via HuggingFace
# instead of calling the Google AI API (requires a GPU with ≥8 GB VRAM).
# MEDGEMMA_LOCAL=1

# ── Note parser / Nora explanation fallback ────────────────────────────────────
# OpenAI API key — used for clinical note parsing (note_parser.py) and as
# the final fallback explanation model when MedGemma/BioGPT are unavailable.
OPENAI_API_KEY=your-openai-api-key

# ── Genomics transformer models (optional, GPU-heavy) ─────────────────────────
# Set to 1 to enable ESM-2, DNABERT-2, Nucleotide Transformer, and HyenaDNA.
# Disabled by default — requires significant GPU memory (≥16 GB recommended).
GENOMICS_MODELS_ENABLED=0

# ── Service config ─────────────────────────────────────────────────────────────
# HTTP port (Railway injects $PORT automatically; this is the local default).
PORT=8080

# ── Causal calibration cron (scripts/causal_calibration.py) ───────────────────
# Base URL of the Nuralix API service (Railway internal network).
API_BASE_URL=http://api:3000

# Bearer token that the calibration script presents to the API.
# Must match a valid Nuralix internal service token.
CALIBRATION_TOKEN=your-calibration-token

# Minimum number of outcome samples required before calibration runs.
MIN_SAMPLES=100

# Set to 1 to perform a dry-run (compute new weights but do not persist them).
DRY_RUN=0
