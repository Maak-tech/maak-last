{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["cd \"$RESOURCE_DIR\" && npm run build"],
      "runtime": "nodejs22"
    }
  ],
  "hosting": {
    "site": "maak-5caad",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/garmin/push",
        "function": "garminPushWebhook"
      },

      {
        "source": "/dexcom-callback",
        "destination": "/dexcom-callback.html"
      },
      {
        "source": "/withings-callback",
        "destination": "/withings-callback.html"
      },
      {
        "source": "/fitbit-callback",
        "destination": "/fitbit-callback.html"
      },
      {
        "source": "/garmin-callback",
        "destination": "/garmin-callback.html"
      },
      {
        "source": "/oura-callback",
        "destination": "/oura-callback.html"
      },
      {
        "source": "/samsung-health-callback",
        "destination": "/samsung-health-callback.html"
      },
      {
        "source": "/privacy-policy",
        "destination": "/privacy-policy.html"
      },
      {
        "source": "/terms-conditions",
        "destination": "/terms-conditions.html"
      },

      {
        "source": "/v1/**",
        "function": "maakApi"
      },

      {
        "source": "/fhir/**",
        "function": "fhirApi"
      },
      {
        "source": "/.well-known/smart-configuration",
        "function": "fhirApi"
      },

      {
        "source": "/auth/**",
        "function": "smartAuth"
      },
      {
        "source": "/.well-known/jwks.json",
        "function": "smartAuth"
      }
    ]
  }
}
