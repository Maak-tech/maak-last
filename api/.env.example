# Database
DATABASE_URL=postgresql://user:password@host/maak?sslmode=require

# Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=https://api.nuralix.ai

# Storage (Tigris S3-compatible)
TIGRIS_ACCESS_KEY=your-key
TIGRIS_SECRET_KEY=your-secret
TIGRIS_BUCKET=nuralix
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev

# File encryption (32-byte hex key)
FILE_ENCRYPTION_KEY=your-32-byte-hex-key

# Bunny.net CDN
BUNNY_SECRET=your-bunny-secret
BUNNY_CDN_URL=https://nuralix.b-cdn.net

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-token

# Autumn billing
AUTUMN_API_KEY=your-autumn-key
AUTUMN_WEBHOOK_SECRET=your-autumn-webhook-secret

# RevenueCat webhooks
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# OpenAI (for Nora)
OPENAI_API_KEY=your-openai-key

# Twilio (for OTP + emergency SMS)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=+1...

# ML service (Railway internal)
ML_SERVICE_URL=http://ml-service:8000

# Environment
NODE_ENV=production
PORT=3000
