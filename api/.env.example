# ── Nuralix API Environment Variables ────────────────────────────────────────
# Copy this file to .env (local) or set these in your Railway / Fly / Docker
# environment.  NEVER commit a file containing real secrets to git.
#
# Required variables (the server will exit on startup if any are missing):
#   DATABASE_URL, BETTER_AUTH_SECRET, JWT_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/nuralix

# Production (Neon serverless Postgres — requires a BAA for HIPAA):
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/nuralix?sslmode=require

# ── Authentication (better-auth) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.nuralix.ai

# ── JWT (issued by /api/auth/* for mobile app and hospital integration) ────────
# Generate with: openssl rand -base64 32
# Must be different from BETTER_AUTH_SECRET.
JWT_SECRET=

# ── Storage (Tigris S3-compatible) ────────────────────────────────────────────
TIGRIS_ACCESS_KEY=
TIGRIS_SECRET_KEY=
TIGRIS_BUCKET=nuralix
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev

# ── File encryption ────────────────────────────────────────────────────────────
# 32-byte hex key for encrypting uploaded files at rest.
# Generate with: openssl rand -hex 32
FILE_ENCRYPTION_KEY=

# ── Bunny.net CDN ──────────────────────────────────────────────────────────────
BUNNY_SECRET=
BUNNY_CDN_URL=https://nuralix.b-cdn.net

# ── Expo Push Notifications ────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── Autumn billing ─────────────────────────────────────────────────────────────
AUTUMN_API_KEY=
AUTUMN_WEBHOOK_SECRET=

# ── RevenueCat webhooks ────────────────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=

# ── Token encryption ─────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens (wearable credentials) stored in
# the users table JSONB fields.  Required — the server exits on startup if missing.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Better-auth Dashboard (optional) ─────────────────────────────────────────
# Enables session reporting to the better-auth infrastructure dashboard.
# Obtain at https://better-auth.com/dashboard
# Safe to leave empty in local development — auth still works without it.
BETTER_AUTH_API_KEY=

# ── OpenAI (Nora AI health assistant) ─────────────────────────────────────────
OPENAI_API_KEY=
# Optional premium key for Realtime voice sessions (falls back to OPENAI_API_KEY)
# OPENAI_PREMIUM_API_KEY=
# Set to "true" once your OpenAI Enterprise BAA is in place.
# Enables Zero Data Retention (ZDR) so OpenAI does not store request/response data.
# DO NOT set to true without a signed BAA — it will be refused without one.
OPENAI_ZDR=false

# ── Twilio (OTP + emergency SMS) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1

# ── ML service ─────────────────────────────────────────────────────────────────
# Railway internal URL — not exposed to the public internet
ML_SERVICE_URL=http://ml-service:8000

# ── Sentry error tracking ────────────────────────────────────────────────────
# Leave blank to disable Sentry (local dev / CI).
# In production, set to your Sentry project DSN.
SENTRY_DSN=

# ── Redis (optional — enables multi-instance rate limiting) ───────────────────
# Leave empty for single-instance deployments (uses in-memory store).
# Set to a Redis connection string to enable Redis-backed rate limiting across
# multiple replicas. Example: redis://default:password@redis.example.com:6379
REDIS_URL=

# ── Social OAuth (better-auth providers) ──────────────────────────────────────
# Google — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In — create a Service ID at https://developer.apple.com/
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Application URLs ───────────────────────────────────────────────────────────
# Public-facing app URL — used in OAuth callback URLs and email links
APP_URL=https://app.nuralix.ai

# ── Email (SendGrid) ───────────────────────────────────────────────────────────
# Obtain at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Verified sender address configured in SendGrid
FROM_EMAIL=noreply@nuralix.ai

# ── Garmin Connect OAuth ────────────────────────────────────────────────────────
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# OAuth redirect URI — must match what is registered in the Garmin developer console.
# For local dev, use an ngrok tunnel: https://<your-tunnel>.ngrok.io/garmin-callback
GARMIN_REDIRECT_URI=https://app.nuralix.ai/garmin-callback

# ── Admin API ──────────────────────────────────────────────────────────────────
# Secret required by internal admin endpoints (/admin/*).
# Generate with: openssl rand -base64 32
ADMIN_SECRET=

# ── Logging ────────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
# Defaults to "info" if not set.
LOG_LEVEL=info

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
