# ── Hospital Web Dashboard Environment Variables ──────────────────────────────
# Copy this file to .env.local (Next.js reads .env.local automatically).
# NEVER commit .env.local to git.
#
# Variables prefixed NEXT_PUBLIC_ are embedded in the browser bundle at build
# time and are visible to anyone who inspects the page source.  Do NOT put
# secrets (JWT_SECRET, DB passwords, API keys) in NEXT_PUBLIC_ variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Hospital API server ────────────────────────────────────────────────────────
# URL of the hospital-dashboard server (Hono, port 3001).
# All API calls from the Next.js app proxy through this URL.
# Local development (Docker Compose):
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production — replace with the public HTTPS URL of the deployed server:
# NEXT_PUBLIC_API_URL=https://hospital-api.nuralix.ai

# ── WebSocket endpoint ─────────────────────────────────────────────────────────
# Used by the dashboard to receive real-time camera-match notifications.
# Derived from NEXT_PUBLIC_API_URL in code (ws:// / wss://), but can be
# overridden here if the WS endpoint is on a different host/path.
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Optional: Sentry error tracking ───────────────────────────────────────────
# Leave blank to disable Sentry.  Set to your Sentry project DSN in production.
NEXT_PUBLIC_SENTRY_DSN=
