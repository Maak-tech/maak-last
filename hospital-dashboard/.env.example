# ── Hospital Dashboard Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values before running.
# NEVER commit the actual .env file to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Docker Postgres):
DATABASE_URL=postgres://hospital:hospital@localhost:5432/hospital_db

# Production: point to shared Neon DB (requires Neon BAA)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/hospital_db?sslmode=require

# ── CompreFace (facial recognition) ──────────────────────────────────────────
COMPREFACE_URL=http://localhost:8000

# Get this from CompreFace admin UI after first boot:
# 1. Open http://localhost:8000/login
# 2. Login: admin@exadel.com / password
# 3. Go to API Keys -> Create -> copy key below
COMPREFACE_API_KEY=

# ── JWT authentication ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ── Encryption keys ────────────────────────────────────────────────────────
# AES-256 key for encrypting sensitive DB fields (biometric subject IDs, RTSP URLs)
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the Next.js web dashboard (for CORS allowlist)
WEB_URL=http://localhost:3000

# URL of the Expo development server (for CORS allowlist — local dev only)
# Expo Metro bundler runs on port 19006 by default.
# In production this can be omitted; native app requests are not browser-origin-gated.
EXPO_URL=http://localhost:19006

# URL of the main Nuralix API (used by /enroll/self and /patient/qr/generate to validate
# patient better-auth sessions via GET /api/auth/verify-session).
# Required for patient self-enrollment and QR generation from the Expo mobile app.
#
# ⚠️  PORT CONFLICT IN LOCAL DEV:
# The Next.js web dashboard (WEB_URL above) also defaults to port 3000.
# To run both locally at the same time, start the main Nuralix API on a different port:
#   PORT=3002 bun run dev   (in the api/ directory)
# then set:
#   MAIN_API_URL=http://localhost:3002
#
# In production, MAIN_API_URL points to the deployed Railway API:
# MAIN_API_URL=https://api.nuralix.ai
MAIN_API_URL=http://localhost:3002

# ── Web app (Next.js) ───────────────────────────────────────────────────────
# Set this in hospital-dashboard/web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Expo mobile app ────────────────────────────────────────────────────────
# Set this in the root .env or app.config.js
EXPO_PUBLIC_HOSPITAL_API_URL=http://localhost:3001
