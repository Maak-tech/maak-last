# ── Nuralix Mobile App — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the client; all others
# are build-time only (used by app.config.js / EAS Build secrets).

# ── API ────────────────────────────────────────────────────────────────────────
# Base URL of the Nuralix REST API (no trailing slash).
EXPO_PUBLIC_API_URL=https://api.nuralix.ai

# ── iOS JS Engine ──────────────────────────────────────────────────────────────
# Override the JS engine for iOS builds. Options: 'hermes' (default) | 'jsc'
# EXPO_PUBLIC_IOS_JS_ENGINE=hermes

# ── Fitbit OAuth ───────────────────────────────────────────────────────────────
# Create an app at https://dev.fitbit.com/apps/new
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# ── Samsung Health ─────────────────────────────────────────────────────────────
# Register at https://developer.samsung.com/health
SAMSUNG_HEALTH_CLIENT_ID=your-samsung-client-id
SAMSUNG_HEALTH_CLIENT_SECRET=your-samsung-client-secret
# Redirect URI registered in the Samsung Health developer console
SAMSUNG_HEALTH_REDIRECT_URI=https://app.nuralix.ai/samsung-health-callback

# ── Withings OAuth ─────────────────────────────────────────────────────────────
# Create an app at https://developer.withings.com/
WITHINGS_CLIENT_ID=your-withings-client-id
WITHINGS_CLIENT_SECRET=your-withings-client-secret
# Override the Withings API base URL (optional; default shown)
# WITHINGS_API_BASE=https://wbsapi.withings.net

# ── Oura OAuth ─────────────────────────────────────────────────────────────────
# Register at https://cloud.ouraring.com/v2/docs
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret
OURA_REDIRECT_URI=https://app.nuralix.ai/oura-callback

# ── Dexcom OAuth ───────────────────────────────────────────────────────────────
# Register at https://developer.dexcom.com/
DEXCOM_CLIENT_ID=your-dexcom-client-id
DEXCOM_CLIENT_SECRET=your-dexcom-client-secret
DEXCOM_REDIRECT_URI=https://app.nuralix.ai/dexcom-callback

# ── Garmin Connect ─────────────────────────────────────────────────────────────
# Register at https://developer.garmin.com/gc-developer-program/
GARMIN_REDIRECT_URI=https://app.nuralix.ai/garmin-callback

# ── RevenueCat ─────────────────────────────────────────────────────────────────
# Public (client-safe) SDK keys — get them at https://app.revenuecat.com/
# Use platform-specific keys when possible (avoids iOS key on Android / vice versa).
PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-ios-public-key
PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-android-public-key
# Fallback single-platform key (used when platform-specific keys are absent)
# PUBLIC_REVENUECAT_API_KEY=your-public-key

# RevenueCat product identifiers (non-secret, safe in client bundle)
REVENUECAT_ENTITLEMENT_ID=premium
REVENUECAT_OFFERING_ID=default

# ── Google Firebase (native SDKs — Sentry Crashlytics + Analytics) ─────────────
# Provide the file contents as a base64-encoded string OR as raw JSON/XML.
# EAS Build reads these from EAS Secrets and writes the native config files at build time.
#
# Android: google-services.json
#   Encode: base64 -i google-services.json | tr -d '\n'
GOOGLE_SERVICES_JSON=base64-encoded-google-services-json

# iOS: GoogleService-Info.plist
#   Encode: base64 -i GoogleService-Info.plist | tr -d '\n'
GOOGLE_SERVICE_INFO_PLIST=base64-encoded-google-service-info-plist
# Alternate key name also accepted by app.config.js:
# GOOGLE_SERVICES_INFO_PLIST=...

# ── Sentry ─────────────────────────────────────────────────────────────────────
# DSN for Sentry error tracking — find it at https://sentry.io/ under your project settings.
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
