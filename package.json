{
  "name": "nuralix-app",
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "build:ios:dev": "eas build -p ios --profile development",
    "build:android:dev": "eas build -p android --profile development",
    "build:dev": "eas build --profile development --platform all",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:android:preview": "eas build -p android --profile preview",
    "build:ios:production": "eas build -p ios --profile production",
    "build:android:production": "eas build -p android --profile production",
    "build:list": "eas build:list",
    "validate:env": "npx tsx scripts/validate-env.ts",
    "validate:production": "npx tsx scripts/validate-production.ts",
    "verify:secrets": "npx tsx scripts/verify-secrets.ts",
    "check:nora": "npx tsx scripts/check-nora-config.ts",
    "check:openai": "npx tsx scripts/check-openai-key.ts",
    "test:websocket": "npx tsx scripts/test-websocket.ts",
    "test:ppg": "npx tsx scripts/test-ppg.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
